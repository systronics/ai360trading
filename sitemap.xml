---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">

  {% comment %}
  ─────────────────────────────────────────────────────────
  SECTION 1: CORE STATIC PAGES
  Priority 0.8 | changefreq: monthly
  Uses last_modified_at from page frontmatter — never site.time
  ─────────────────────────────────────────────────────────
  {% endcomment %}
  {% for page in site.pages %}
    {% unless page.sitemap == false
          or page.url contains "assets"
          or page.url contains "css"
          or page.url contains "js"
          or page.url contains "feed"
          or page.url contains "404"
          or page.url contains "sitemap"
          or page.url contains "page" %}
    <url>
      <loc>{{ site.url }}{{ page.url | replace: 'index.html', '' }}</loc>
      {% if page.last_modified_at %}
        <lastmod>{{ page.last_modified_at | date_to_xmlschema }}</lastmod>
      {% elsif page.date %}
        <lastmod>{{ page.date | date_to_xmlschema }}</lastmod>
      {% else %}
        <lastmod>2025-12-01T00:00:00+05:30</lastmod>
      {% endif %}
      <changefreq>monthly</changefreq>
      <priority>0.8</priority>
    </url>
    {% endunless %}
  {% endfor %}

  {% comment %}
  ─────────────────────────────────────────────────────────
  SECTION 2: POSTS — split by age for honest signals
  Today / yesterday  → priority 1.0 | changefreq: daily
  Within last 7 days → priority 0.9 | changefreq: daily
  Within last 30 days→ priority 0.8 | changefreq: weekly
  Older              → priority 0.6 | changefreq: monthly
  lastmod uses last_modified_at if set, else post.date
  ─────────────────────────────────────────────────────────
  {% endcomment %}
  {% assign now_ts   = site.time | date: "%s" | plus: 0 %}
  {% assign day_secs = 86400 %}

  {% for post in site.posts %}
    {% unless post.sitemap == false %}

      {% assign post_ts  = post.date | date: "%s" | plus: 0 %}
      {% assign age_secs = now_ts | minus: post_ts %}
      {% assign age_days = age_secs | divided_by: day_secs %}

      {% if age_days <= 1 %}
        {% assign post_priority   = "1.0" %}
        {% assign post_changefreq = "daily" %}
      {% elsif age_days <= 7 %}
        {% assign post_priority   = "0.9" %}
        {% assign post_changefreq = "daily" %}
      {% elsif age_days <= 30 %}
        {% assign post_priority   = "0.8" %}
        {% assign post_changefreq = "weekly" %}
      {% else %}
        {% assign post_priority   = "0.6" %}
        {% assign post_changefreq = "monthly" %}
      {% endif %}

    <url>
      <loc>{{ site.url }}{{ post.url }}</loc>
      {% if post.last_modified_at %}
        <lastmod>{{ post.last_modified_at | date_to_xmlschema }}</lastmod>
      {% else %}
        <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
      {% endif %}
      <changefreq>{{ post_changefreq }}</changefreq>
      <priority>{{ post_priority }}</priority>
    </url>

    {% endunless %}
  {% endfor %}

</urlset>
